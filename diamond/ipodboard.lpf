# LCMXO2-2000HC-4TG100C — pin LOCATEs extracted from the FINAL routed board
# (workspace/ipod-cf-udma/ipod-cf-udma.kicad_pcb, U1 pad -> net, 2026-07-01).
# Port names match rtl/fpga_top.v. Board nets in comments.

BLOCK RESETPATHS;
BLOCK ASYNCPATHS;

FREQUENCY NET "clk" 66.500000 MHz;

# keep JTAG alive: JTAGENB (pin 82) is NC on this board, so JTAG_PORT=DISABLE
# would be unrecoverable. Config boots from internal flash; all config ports off.
SYSCONFIG JTAG_PORT=ENABLE MASTER_SPI_PORT=DISABLE SLAVE_SPI_PORT=DISABLE I2C_PORT=DISABLE;

IOBUF ALLPORTS IO_TYPE=LVCMOS33;

# ---- host side (iPod 50-pin: HD*/H* nets) --------------------------------
LOCATE COMP "HS_DD[0]"  SITE "75";   # HD0
LOCATE COMP "HS_DD[1]"  SITE "74";   # HD1
LOCATE COMP "HS_DD[2]"  SITE "71";   # HD2
LOCATE COMP "HS_DD[3]"  SITE "70";   # HD3
LOCATE COMP "HS_DD[4]"  SITE "69";   # HD4
LOCATE COMP "HS_DD[5]"  SITE "68";   # HD5
LOCATE COMP "HS_DD[6]"  SITE "67";   # HD6
LOCATE COMP "HS_DD[7]"  SITE "66";   # HD7
LOCATE COMP "HS_DD[8]"  SITE "65";   # HD8
LOCATE COMP "HS_DD[9]"  SITE "64";   # HD9
LOCATE COMP "HS_DD[10]" SITE "63";   # HD10
LOCATE COMP "HS_DD[11]" SITE "62";   # HD11
LOCATE COMP "HS_DD[12]" SITE "61";   # HD12
LOCATE COMP "HS_DD[13]" SITE "60";   # HD13
LOCATE COMP "HS_DD[14]" SITE "59";   # HD14
LOCATE COMP "HS_DD[15]" SITE "58";   # HD15
LOCATE COMP "HS_CS0_N"  SITE "32";   # HCS0
LOCATE COMP "HS_CS1_N"  SITE "34";   # HCS1
LOCATE COMP "HS_A0"     SITE "29";   # HDA0
LOCATE COMP "HS_A1"     SITE "30";   # HDA1
LOCATE COMP "HS_A2"     SITE "31";   # HDA2
LOCATE COMP "HS_IOR_N"  SITE "53";   # HDIOR
LOCATE COMP "HS_IOW_N"  SITE "52";   # HDIOW
LOCATE COMP "HS_DMARQ"  SITE "57";   # HDMARQ
LOCATE COMP "HS_DMACK_N" SITE "54";  # HDMACK
LOCATE COMP "HS_RESET_N" SITE "28";  # HRESET
LOCATE COMP "HS_INTRQ"  SITE "27";   # HINTRQ
LOCATE COMP "HS_IORDY"  SITE "51";   # HIORDY

# ---- CF side (True-IDE: CD*/C* nets) --------------------------------------
LOCATE COMP "CF_DD[0]"  SITE "1";    # CD0
LOCATE COMP "CF_DD[1]"  SITE "2";    # CD1
LOCATE COMP "CF_DD[2]"  SITE "3";    # CD2
LOCATE COMP "CF_DD[3]"  SITE "4";    # CD3
LOCATE COMP "CF_DD[4]"  SITE "7";    # CD4
LOCATE COMP "CF_DD[5]"  SITE "8";    # CD5
LOCATE COMP "CF_DD[6]"  SITE "9";    # CD6
LOCATE COMP "CF_DD[7]"  SITE "10";   # CD7
LOCATE COMP "CF_DD[8]"  SITE "12";   # CD8
LOCATE COMP "CF_DD[9]"  SITE "13";   # CD9
LOCATE COMP "CF_DD[10]" SITE "14";   # CD10
LOCATE COMP "CF_DD[11]" SITE "15";   # CD11
LOCATE COMP "CF_DD[12]" SITE "16";   # CD12
LOCATE COMP "CF_DD[13]" SITE "17";   # CD13
LOCATE COMP "CF_DD[14]" SITE "18";   # CD14
LOCATE COMP "CF_DD[15]" SITE "19";   # CD15
LOCATE COMP "CF_CS0_N"  SITE "41";   # CCS0
LOCATE COMP "CF_CS1_N"  SITE "42";   # CCS1
LOCATE COMP "CF_A0"     SITE "38";   # CDA0
LOCATE COMP "CF_A1"     SITE "39";   # CDA1
LOCATE COMP "CF_A2"     SITE "40";   # CDA2
LOCATE COMP "CF_IOR_N"  SITE "24";   # CDIOR
LOCATE COMP "CF_IOW_N"  SITE "25";   # CDIOW
LOCATE COMP "CF_DMARQ"  SITE "20";   # CDMARQ
LOCATE COMP "CF_DMACK_N" SITE "21";  # CDMACK
LOCATE COMP "CF_RESET_N" SITE "37";  # CFRESET
LOCATE COMP "CF_INTRQ"  SITE "36";   # CINTRQ
LOCATE COMP "CF_IORDY"  SITE "35";   # CIORDY

# ---- local -----------------------------------------------------------------
LOCATE COMP "LED"       SITE "78";   # LED_STAT
LOCATE COMP "UART_TX"   SITE "99";   # U_TX
LOCATE COMP "UART_RX"   SITE "98";   # U_RX

# control inputs idle high across CN211 switchover (board has no discrete pulls)
IOBUF PORT "HS_IOR_N"   PULLMODE=UP;
IOBUF PORT "HS_IOW_N"   PULLMODE=UP;
IOBUF PORT "HS_DMACK_N" PULLMODE=UP;
IOBUF PORT "HS_CS0_N"   PULLMODE=UP;
IOBUF PORT "HS_CS1_N"   PULLMODE=UP;
IOBUF PORT "HS_RESET_N" PULLMODE=UP;
IOBUF PORT "CF_DMARQ"   PULLMODE=DOWN;
IOBUF PORT "CF_IORDY"   PULLMODE=UP;
IOBUF PORT "CF_INTRQ"   PULLMODE=DOWN;
IOBUF PORT "UART_RX"    PULLMODE=UP;

# strobes we source + both DD buses: fast edges, 8 mA
IOBUF PORT "HS_IORDY"   DRIVE=8 SLEWRATE=FAST;
IOBUF PORT "HS_DMARQ"   DRIVE=8 SLEWRATE=FAST;
IOBUF PORT "CF_IOR_N"   DRIVE=8 SLEWRATE=FAST;
IOBUF PORT "CF_IOW_N"   DRIVE=8 SLEWRATE=FAST;
IOBUF PORT "HS_DD*"    DRIVE=8 SLEWRATE=FAST;
IOBUF PORT "CF_DD*"    DRIVE=8 SLEWRATE=FAST;
